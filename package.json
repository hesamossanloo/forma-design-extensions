{
  "name": "forma-design-extensions",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "build:fire": "pnpm --filter @hesam/where-is-the-fire build",
    "dev:fire": "pnpm --filter @hesam/where-is-the-fire dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview:fire": "pnpm --filter @hesam/where-is-the-fire preview",
    "typecheck:fire": "pnpm --filter @hesam/where-is-the-fire typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.30.1"
  }
}
